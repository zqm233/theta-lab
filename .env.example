# LLM Configuration (required)
# Supported providers: google, openai, anthropic
LLM_PROVIDER=
LLM_MODEL=
# LLM_BASE_URL=          # Optional: custom endpoint for proxy/acceleration

# Provider API keys (only the one matching your LLM_PROVIDER is required)
# GOOGLE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional: Binance API credentials (for dual investment features)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# Optional: OKX API credentials (for dual investment & MCP modules beyond market)
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_PASSPHRASE=

# Optional: OKX MCP access level ("readonly" or "full", default: readonly)
# readonly = all modules loaded with --read-only (query only, no trading)
# full     = all modules loaded without restriction (trading enabled)
# OKX_MCP_ACCESS=readonly

# Optional: CoinMarketCap MCP (sentiment, technicals, on-chain, macro events)
# Free key: https://pro.coinmarketcap.com/login
# CMC_MCP_API_KEY=

# Optional: FlashAlpha MCP (GEX/DEX/VEX exposure, key levels, options analytics)
# Free tier: 5 requests/day — https://flashalpha.com/profile
# FA_API_KEY=

# Persistence backend (default: sqlite)
# Supported: sqlite, postgres
# PERSISTENCE_BACKEND=sqlite
# DATABASE_URL=                # Required when PERSISTENCE_BACKEND=postgres

# Optional: LangSmith observability (agent tracing)
# Free tier: 5,000 traces/month — https://smith.langchain.com
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=ThetaLab
